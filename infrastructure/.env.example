# Optionix Environment Variables
# Copy this file to .env and fill in all values before running docker-compose
# NEVER commit .env to version control

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
IMAGE_TAG=latest
LOG_LEVEL=info
ENABLE_AUDIT_LOGGING=true

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=optionix
DB_USER=appuser
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── Backend secrets ──────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64_char_jwt_secret_here_use_openssl_rand_hex_32
ENCRYPTION_KEY=CHANGE_ME_32_char_encryption_key

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE_ME_grafana_admin_password
GRAFANA_URL=http://localhost:3001
